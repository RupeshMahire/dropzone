{
    "version": 2,
    "rewrites": [
        {
            "source": "/upload",
            "destination": "/server.js"
        },
        {
            "source": "/download/:path*",
            "destination": "/server.js"
        },
        {
            "source": "/status/:path*",
            "destination": "/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "/public/$1"
        }
    ]
}